{
  "name": "Mobile Testing Suite",
  "flows": {
    "happy-path.yaml": "Complete login to detail view flow",
    "validation-errors.yaml": "Login form validation error states",
    "platform-native.yaml": "Platform-specific gestures (iOS swipe vs Android scroll)",
    "search-results.yaml": "Search flow with env vars and repeat blocks",
    "crud-flow.yaml": "Create item flow with assertions"
  },
  "tags": ["smoke", "regression", "platform-native"],
  "env": {
    "APP_ID": "com.yourapp",
    "BASE_URL": "https://api.yourapp.com",
    "TIMEOUT_MS": 15000
  },
  "config": {
    "maxRefreshRetries": 3,
    "cache": false,
    "delayBetweenCommands": 500,
    "output": {
      "artifactsDir": ".artifacts/maestro",
      "reportFormat": "junit"
    }
  }
}
