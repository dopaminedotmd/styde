{
  "name": "appium-tests",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "appium:ios": "PLATFORM=ios node run-tests.js",
    "appium:android": "PLATFORM=android node run-tests.js",
    "appium:server": "appium --log-level info --log .artifacts/appium-server.log",
    "appium:doctor": "appium-doctor",
    "test:ios": "npm run appium:server & npm run appium:ios",
    "test:android": "npm run appium:server & npm run appium:android"
  },
  "devDependencies": {
    "@wdio/cli": "^8.29.0",
    "@wdio/local-runner": "^8.29.0",
    "@wdio/mocha-framework": "^8.29.0",
    "@wdio/spec-reporter": "^8.29.0",
    "webdriverio": "^8.29.0",
    "appium": "^2.4.0",
    "appium-uiautomator2-driver": "^3.3.0",
    "appium-xcuitest-driver": "^5.5.0",
    "appium-doctor": "^2.0.0"
  },
  "wdio": {
    "specs": ["./run-tests.js"],
    "framework": "mocha",
    "mochaOpts": {
      "timeout": 120000
    },
    "reporters": ["spec"]
  }
}
