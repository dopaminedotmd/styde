{
  "$schema": "https://raw.githubusercontent.com/amzn/style-dictionary/main/examples/advanced/schema.json",
  "source": ["tokens/**/*.json"],
  "platforms": {
    "css": {
      "transformGroup": "custom/css",
      "buildPath": "dist/css/",
      "files": [
        {
          "destination": "tokens.css",
          "format": "custom/css/variables",
          "options": {
            "showFileHeader": true,
            "outputReferences": true
          }
        },
        {
          "destination": "tokens-dark.css",
          "format": "custom/css/variables-dark",
          "options": {
            "showFileHeader": true,
            "outputReferences": true
          }
        }
      ]
    },
    "json": {
      "transformGroup": "custom/json",
      "buildPath": "dist/json/",
      "files": [
        {
          "destination": "tokens.json",
          "format": "custom/json/nested",
          "options": {
            "showFileHeader": false
          }
        },
        {
          "destination": "tokens-flat.json",
          "format": "custom/json/flat",
          "options": {
            "showFileHeader": false
          }
        }
      ]
    },
    "ts": {
      "transformGroup": "custom/ts",
      "buildPath": "dist/ts/",
      "files": [
        {
          "destination": "tokens.ts",
          "format": "custom/typescript/const",
          "options": {
            "showFileHeader": true,
            "outputReferences": true
          }
        },
        {
          "destination": "tokens.d.ts",
          "format": "custom/typescript/types",
          "options": {
            "showFileHeader": true
          }
        }
      ]
    },
    "android": {
      "transformGroup": "android",
      "buildPath": "dist/android/",
      "files": [
        {
          "destination": "colors.xml",
          "format": "android/resources",
          "filter": {
            "attributes": {
              "category": "color"
            }
          }
        },
        {
          "destination": "dimens.xml",
          "format": "android/dimens",
          "filter": {
            "attributes": {
              "category": "size"
            }
          }
        },
        {
          "destination": "font_dimens.xml",
          "format": "android/fontDimens",
          "filter": {
            "attributes": {
              "category": "size"
            }
          }
        }
      ]
    },
    "ios": {
      "transformGroup": "ios",
      "buildPath": "dist/ios/",
      "files": [
        {
          "destination": "StyleDictionaryColor.h",
          "format": "ios/colors.h",
          "className": "StyleDictionaryColor",
          "type": "float",
          "filter": {
            "attributes": {
              "category": "color"
            }
          }
        },
        {
          "destination": "StyleDictionaryColor.m",
          "format": "ios/colors.m",
          "className": "StyleDictionaryColor",
          "type": "float",
          "filter": {
            "attributes": {
              "category": "color"
            }
          }
        },
        {
          "destination": "StyleDictionarySize.h",
          "format": "ios/sizes.h",
          "className": "StyleDictionarySize",
          "type": "float",
          "filter": {
            "attributes": {
              "category": "size"
            }
          }
        },
        {
          "destination": "StyleDictionarySize.m",
          "format": "ios/sizes.m",
          "className": "StyleDictionarySize",
          "type": "float"
        }
      ]
    },
    "scss": {
      "transformGroup": "scss",
      "buildPath": "dist/scss/",
      "files": [
        {
          "destination": "_tokens.scss",
          "format": "scss/variables",
          "options": {
            "showFileHeader": true,
            "outputReferences": true
          }
        }
      ]
    },
    "less": {
      "transformGroup": "less",
      "buildPath": "dist/less/",
      "files": [
        {
          "destination": "_tokens.less",
          "format": "less/variables",
          "options": {
            "showFileHeader": true,
            "outputReferences": true
          }
        }
      ]
    },
    "tailwind": {
      "transformGroup": "js",
      "buildPath": "dist/tailwind/",
      "files": [
        {
          "destination": "tokens.tailwind.js",
          "format": "custom/tailwind/theme",
          "options": {
            "showFileHeader": true
          }
        }
      ]
    },
    "figma": {
      "transformGroup": "custom/figma",
      "buildPath": "dist/figma/",
      "files": [
        {
          "destination": "tokens-figma.json",
          "format": "custom/figma/tokens-studio",
          "options": {
            "showFileHeader": false
          }
        }
      ]
    }
  }
}
