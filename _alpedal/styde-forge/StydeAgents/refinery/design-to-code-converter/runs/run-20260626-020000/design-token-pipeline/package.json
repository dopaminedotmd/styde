{
  "name": "design-token-pipeline",
  "version": "1.0.0",
  "description": "Multi-platform design token pipeline — Style Dictionary + Figma sync + GitHub Actions CI",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.js",
    "build:tokens": "style-dictionary build --config style-dictionary/config.json",
    "build:css": "style-dictionary build --config style-dictionary/config.css.json",
    "build:json": "style-dictionary build --config style-dictionary/config.json.json",
    "build:ts": "style-dictionary build --config style-dictionary/config.ts.json",
    "build:all": "npm run build:tokens && npm run build:css && npm run build:json && npm run build:ts",
    "sync:figma": "node figma-tokens/sync.js",
    "lint:tokens": "node scripts/lint-tokens.js",
    "test": "node scripts/validate-output.js",
    "ci": "npm run lint:tokens && npm run build:all && npm run test"
  },
  "dependencies": {
    "style-dictionary": "^4.3.3",
    "culori": "^4.0.1",
    "chokidar": "^4.0.3"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
