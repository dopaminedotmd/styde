# Hermes Forge — Git ignore

# Python cache
__pycache__/
*.pyc
*.pyo

# Logs
logs/
*.log

# Sandboxes (temporary agent workspaces)
sandbox/

# Exports (zip archives)
exports/*.zip

# Checkpoints (can be large)
checkpoints/
09_CHECKPOINTS/

# Dashboard (Tauri)
Dashboard/src-tauri/target/
Dashboard/node_modules/
Dashboard/dist/

# Python virtual envs
.venv/
venv/
env/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Temp files
*.tmp
*.staging
.env.example
