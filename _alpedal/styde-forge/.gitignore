# Hermes Forge — Git ignore

# Logs
logs/
*.log

# Sandboxes (temporary agent workspaces)
sandbox/

# Exports (zip archives)
exports/*.zip

# Checkpoints (can be large)
checkpoints/

# Python cache
__pycache__/
*.pyc
*.pyo

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Temp files
*.tmp
*.staging
